# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Anthropic API (para generar emails con IA)
# IMPORTANTE: La key se usa solo server-side (Vercel functions).
# En producción, configurar en Vercel Dashboard → Settings → Environment Variables.
# Nunca commitear la key real a git.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# App Config
VITE_APP_NAME=Digpatho CRM

# -----------------------------------------------
# AI Growth System (Python backend — ai_growth_system.py)
# -----------------------------------------------
# Service role key bypasses RLS — required for backend scripts.
# Get it from Supabase Dashboard → Settings → API → service_role key.
# If not set, the system falls back to VITE_SUPABASE_ANON_KEY.
SUPABASE_SERVICE_KEY=your-service-role-key

# -----------------------------------------------
# Vertex AI (Gemini) — búsqueda de emails con Google Search grounding
# -----------------------------------------------
# JSON de Workload Identity Federation (WIF) para autenticarse con GCP
# sin guardar service-account keys. Se configura en Vercel Dashboard →
# Settings → Environment Variables → OIDC tab.
# El OIDC token de Vercel se federa automáticamente con GCP.
GCP_WIF_CONFIG={"type":"external_account","audience":"//iam.googleapis.com/...","token_url":"https://sts.googleapis.com/v1/token",...}

# Región de Vertex AI (default: us-central1)
# VERTEX_AI_REGION=us-central1
